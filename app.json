{
  "expo": {
    "name": "Spanish4Hoteleros",
    "slug": "spanish4hoteleros",
    "version": "1.0.0",
    "scheme": "spanish4hoteleros",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B3A5C"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spanish4hoteleros.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Spanish4Hoteleros needs access to your microphone to record your spoken Spanish practice and provide feedback on pronunciation.",
        "NSPhotoLibraryUsageDescription": "Spanish4Hoteleros may need access to your photo library for profile pictures or learning materials."
      }
    },
    "android": {
      "package": "com.spanish4hoteleros.app",
      "adaptiveIcon": {
        "backgroundColor": "#F8F5F0",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-font",
      "expo-web-browser",
      "expo-sqlite",
      "expo-apple-authentication",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Spanish4Hoteleros to access the microphone for speaking practice.",
          "speechRecognitionPermission": "Allow Spanish4Hoteleros to use speech recognition for speaking practice."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3fdc630d-c767-4152-9706-d3b2287559c2"
      }
    }
  }
}
